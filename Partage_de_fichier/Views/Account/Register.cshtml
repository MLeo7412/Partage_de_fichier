@model Partage_de_fichier.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Inscription";
}

<div class="container mt-5">
    <h2>Créer un compte</h2>
    <hr />

    <div class="row">
        <div class="col-md-4">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="NomUtilisateur" class="control-label">Nom d'utilisateur</label>
                    <input asp-for="NomUtilisateur" class="form-control" />
                    <span asp-validation-for="NomUtilisateur" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="MotDePasse" class="control-label">Mot de passe</label>
                    <input asp-for="MotDePasse" class="form-control" />
                    <span asp-validation-for="MotDePasse" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ConfirmationMotDePasse" class="control-label">Confirmer le mot de passe</label>
                    <input asp-for="ConfirmationMotDePasse" class="form-control" />
                    <span asp-validation-for="ConfirmationMotDePasse" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">S'inscrire</button>
                </div>
            </form>
        </div>
    </div>
</div>